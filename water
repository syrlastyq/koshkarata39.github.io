// ── CHATBOT ────────────────────────────────────
function ChatBot() {
  const [open, setOpen]       = useState(false);
  const [msgs, setMsgs]       = useState([]);
  const [input, setInput]     = useState("");
  const [busy, setBusy]       = useState(false);
  const [showSug, setShowSug] = useState(true);
  const histRef  = useRef([]);
  const bottomRef = useRef(null);
  const inputRef  = useRef(null);

  useEffect(() => {
    if (open && msgs.length === 0) {
      setMsgs([{ role: "bot", text: "Сәлем! Здравствуйте! ☢\n\nЯ эксперт-бот по хвостохранилищу Кошкар-Ата. Задайте любой вопрос об этой экологической проблеме.", time: ts() }]);
    }
    if (open) setTimeout(() => inputRef.current?.focus(), 300);
  }, [open]);

  useEffect(() => { bottomRef.current?.scrollIntoView({ behavior: "smooth" }); }, [msgs]);

  async function send(text) {
    if (!text.trim() || busy) return;
    setInput("");
    setShowSug(false);
    const userMsg = { role: "user", text, time: ts() };
    setMsgs(m => [...m, userMsg, { role: "typing" }]);
    histRef.current = [...histRef.current, { role: "user", content: text }];
    setBusy(true);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 800,
          system: SYSTEM,
          messages: histRef.current,
        }),
      });
      const data = await res.json();
      const reply = (data.content || []).map(b => b.text || "").join("") || "Ошибка. Попробуйте ещё раз.";
      histRef.current = [...histRef.current, { role: "assistant", content: reply }];
      setMsgs(m => [...m.filter(x => x.role !== "typing"), { role: "bot", text: reply, time: ts() }]);
    } catch {
      setMsgs(m => [...m.filter(x => x.role !== "typing"), { role: "bot", text: "Нет соединения. Попробуйте позже.", time: ts() }]);
    }
    setBusy(false);
    setTimeout(() => inputRef.current?.focus(), 100);
  }

  const pulse = `@keyframes ring-pulse { 0%{opacity:.9;transform:scale(1)} 100%{opacity:0;transform:scale(1.6)} }
  @keyframes dot-bounce { 0%,60%,100%{transform:translateY(0);opacity:.4} 30%{transform:translateY(-5px);opacity:1} }
  @keyframes slide-up { from{opacity:0;transform:translateY(14px) scale(.96)} to{opacity:1;transform:translateY(0) scale(1)} }
  @keyframes msg-in { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }`;

  return (
    <>
      <style>{pulse}</style>

      {/* Toggle button */}
      <Box style={{ position: "fixed", bottom: "2rem", left: "2rem", zIndex: 1000 }}>
        <Box style={{ position: "relative" }}>
          {/* pulse ring */}
          <Box style={{
            position: "absolute", inset: -6, borderRadius: "50%",
            border: `2px solid ${C.red}66`,
            animation: "ring-pulse 2.5s ease-out infinite",
            pointerEvents: "none",
          }} />
          <button onClick={() => setOpen(o => !o)} style={{
            width: 58, height: 58, borderRadius: "50%",
            background: open ? "#9b2335" : C.red,
            border: "none", cursor: "pointer",
            display: "flex", alignItems: "center", justifyContent: "center",
            boxShadow: `0 4px 20px ${C.red}55`,
            transition: "all .25s",
          }}>
            {open
              ? <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" strokeWidth="2.5" strokeLinecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
              : <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" strokeWidth="2" strokeLinecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            }
          </button>
        </Box>
      </Box>

      {/* Chat window */}
      {open && (
        <Box style={{
          position: "fixed", bottom: "6.5rem", left: "2rem", zIndex: 999,
          width: "min(360px, calc(100vw - 2rem))",
          height: "min(520px, 70vh)",
          background: "#0a1520",
          border: `1px solid ${C.red}55`,
          boxShadow: "0 16px 50px #00000099",
          display: "flex", flexDirection: "column", overflow: "hidden",
          animation: "slide-up .3s ease",
        }}>
          {/* Header */}
          <Box style={{ background: C.card, borderBottom: `1px solid ${C.red}33`, padding: "1rem 1.2rem", display: "flex", alignItems: "center", gap: ".8rem", flexShrink: 0 }}>
            <Box style={{
              width: 38, height: 38, borderRadius: "50%", flexShrink: 0,
              background: `${C.red}22`, border: `1.5px solid ${C.red}88`,
              display: "flex", alignItems: "center", justifyContent: "center",
              fontSize: "1.1rem", position: "relative",
            }}>
              ☢
              <Box style={{ position: "absolute", bottom: 1, right: 1, width: 8, height: 8, borderRadius: "50%", background: C.green, border: `2px solid #0a1520` }} />
            </Box>
            <Box style={{ flex: 1 }}>
              <div style={{ fontFamily: "Georgia,serif", fontWeight: 700, fontSize: ".9rem", letterSpacing: 2, color: C.white, textTransform: "uppercase" }}>Кошкар-Ата Бот</div>
              <div style={{ fontSize: ".58rem", color: C.muted, letterSpacing: 1.5, marginTop: ".15rem", fontFamily: "monospace" }}>// Эксперт по экологии · Онлайн</div>
            </Box>
            <button onClick={() => setOpen(false)} style={{ background: "none", border: "none", color: C.muted, cursor: "pointer", padding: ".2rem", display:"flex" }}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </Box>

          {/* Messages */}
          <Box style={{ flex: 1, overflowY: "auto", padding: "1rem", display: "flex", flexDirection: "column", gap: ".85rem" }}>
            {msgs.map((m, i) => {
              if (m.role === "typing") return (
                <Box key={i} style={{ display: "flex", gap: 4, padding: ".7rem .9rem", background: C.card, borderLeft: `2px solid ${C.red}`, width: "fit-content", borderRadius: 2 }}>
                  {[0, .2, .4].map((d, j) => <span key={j} style={{ width: 6, height: 6, borderRadius: "50%", background: C.red, display: "inline-block", animation: `dot-bounce 1.2s ${d}s ease-in-out infinite` }} />)}
                </Box>
              );
              const isUser = m.role === "user";
              const isOff  = m.text?.includes("не в моей компетенции") || m.text?.includes("мамандығым");
              return (
                <Box key={i} style={{ alignSelf: isUser ? "flex-end" : "flex-start", maxWidth: "88%", animation: "msg-in .25s ease" }}>
                  <Box style={{
                    padding: ".65rem .9rem", fontSize: ".8rem", lineHeight: 1.65, borderRadius: 2,
                    background: isUser ? `${C.red}22` : isOff ? `${C.amber}11` : C.card,
                    color: isOff ? C.muted : C.white,
                    borderLeft: isUser ? "none" : `2px solid ${isOff ? C.amber : C.red}`,
                    borderRight: isUser ? `2px solid ${C.amber}` : "none",
                    whiteSpace: "pre-wrap",
                  }}>{m.text}</Box>
                  <Box style={{ fontSize: ".58rem", color: "#4a6070", marginTop: ".25rem", textAlign: isUser ? "right" : "left", fontFamily: "monospace", letterSpacing: 1 }}>
                    {isUser ? `вы · ${m.time}` : `☢ бот · ${m.time}`}
                  </Box>
                </Box>
              );
            })}
            <div ref={bottomRef} />
          </Box>

          {/* Suggestions */}
          {showSug && (
            <Box style={{ padding: ".5rem 1rem .3rem", display: "flex", flexWrap: "wrap", gap: ".35rem", borderTop: "1px solid rgba(255,255,255,.04)", flexShrink: 0 }}>
              {SUGS.map(s => (
                <button key={s} onClick={() => send(s)} disabled={busy} style={{
                  background: `${C.red}14`, border: `1px solid ${C.red}44`, color: C.muted,
                  fontSize: ".62rem", padding: ".28rem .6rem", cursor: "pointer",
                  fontFamily: "inherit", borderRadius: 2, transition: "all .2s",
                }}
                  onMouseEnter={e => { e.target.style.background = `${C.red}2a`; e.target.style.color = C.white; }}
                  onMouseLeave={e => { e.target.style.background = `${C.red}14`; e.target.style.color = C.muted; }}
                >{s}</button>
              ))}
            </Box>
          )}

          {/* Input */}
          <Box style={{ background: "#080f18", borderTop: "1px solid rgba(255,255,255,.05)", padding: ".7rem .8rem", display: "flex", gap: ".5rem", flexShrink: 0 }}>
            <input
              ref={inputRef}
              value={input}
              onChange={e => setInput(e.target.value)}
              onKeyDown={e => { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); send(input); } }}
              placeholder="Задайте вопрос о Кошкар-Ата..."
              disabled={busy}
              style={{
                flex: 1, background: C.card, border: "1px solid rgba(255,255,255,.08)",
                color: C.white, fontFamily: "inherit", fontSize: ".78rem",
                padding: ".55rem .85rem", outline: "none", borderRadius: 2,
              }}
            />
            <button onClick={() => send(input)} disabled={busy || !input.trim()} style={{
              background: busy || !input.trim() ? "#2a1a1e" : C.red,
              border: "none", width: 38, height: 38, borderRadius: 2,
              display: "flex", alignItems: "center", justifyContent: "center",
              cursor: busy || !input.trim() ? "not-allowed" : "pointer",
              transition: "background .2s", flexShrink: 0,
            }}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" strokeWidth="2" strokeLinecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </Box>
        </Box>
      )}
    </>
  );
}

