const Box = ({ style, children, ...p }) => (
  <div style={{ boxSizing: "border-box", ...style }} {...p}>{children}</div>
);

function StatCard({ num, unit, label, accent }) {
  return (
    <Box style={{
      flex: 1, background: C.card, padding: "2rem 1rem",
      borderTop: `3px solid ${accent}`, textAlign: "center",
